# LinkedIn credentials (required)
LINKEDIN_USERNAME=seu_email_linkedin
LINKEDIN_PASSWORD=sua_senha_linkedin

# PostgreSQL connection string (required)
WEBCRAWLER_DB_CONNECTION=Host=localhost;Port=5432;Database=ProjetoDb;Username=postgres;Password=sua_senha

# Optional: fast test mode
WEBCRAWLER_TEST_MODE=true
WEBCRAWLER_MAX_PAGES_PER_CYCLE=1
WEBCRAWLER_MAX_APPLY_PER_CYCLE=2
WEBCRAWLER_CYCLE_WAIT_MINUTES=1
WEBCRAWLER_DISABLE_DATABASE=true

# Optional: keep Chrome logged-in profile between runs (recommended)
WEBCRAWLER_USE_PERSISTENT_PROFILE=true

# Optional: if LinkedIn shows checkpoint/captcha, wait this many minutes for manual resolution
WEBCRAWLER_MANUAL_CHALLENGE_WAIT_MINUTES=3

# Optional: persist ignored links across restarts
WEBCRAWLER_PERSIST_IGNORED_LINKS=true

# Optional: persist successful application links across restarts
WEBCRAWLER_PERSIST_SUCCESSFUL_LINKS=true

# Optional: auto-fill required questions/fields before skipping a job
WEBCRAWLER_AUTO_FILL_MANDATORY_FIELDS=true
WEBCRAWLER_DEFAULT_FIRST_NAME=Clovis
WEBCRAWLER_DEFAULT_LAST_NAME=Silva
WEBCRAWLER_DEFAULT_EMAIL=seu_email_linkedin
WEBCRAWLER_DEFAULT_PHONE=11999999999
WEBCRAWLER_DEFAULT_LOCATION=Sao Paulo
WEBCRAWLER_DEFAULT_YEARS_EXPERIENCE=3
WEBCRAWLER_DEFAULT_SALARY=7000
WEBCRAWLER_DEFAULT_CHECKBOX_TRUE=true
WEBCRAWLER_DEFAULT_WORK_AUTHORIZATION=true
WEBCRAWLER_DEFAULT_NEED_VISA_SPONSORSHIP=false
WEBCRAWLER_DEFAULT_WEBSITE=
WEBCRAWLER_DEFAULT_LINKEDIN_URL=
WEBCRAWLER_DEFAULT_GITHUB_URL=
WEBCRAWLER_DEFAULT_GENERIC_TEXT=Tenho experiencia compativel com a vaga e disponibilidade para atuar no escopo solicitado.
